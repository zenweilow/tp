@startuml
title SetMany Command Class View
hide circles

class Parser {
  + parse(input: String): ParsedCommand
}

class CG2StocksTracker {
  + run()
}

class Storage {
  + loadPriceUpdates(csvPath: Path, portfolio: Portfolio): BulkUpdateResult
  + save(portfolioBook: PortfolioBook)
}

class PortfolioBook {
  + getActivePortfolio(): Portfolio
}

class Portfolio {
  + setPriceForTicker(ticker: String, price: double): int
}

class Ui {
  + showBulkUpdateResult(result: Storage.BulkUpdateResult)
}

CG2StocksTracker ..> PortfolioBook : getActivePortfolio()
CG2StocksTracker ..> Storage : loadPriceUpdates(file, portfolio)
Storage ..> Portfolio : setPriceForTicker(...)
CG2StocksTracker ..> Storage : save(...)
CG2StocksTracker ..> Ui : showBulkUpdateResult(...)
@enduml
