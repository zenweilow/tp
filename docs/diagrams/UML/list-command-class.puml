'@@author RishabhShenoy03
@startuml
title List Command Class View
hide circle

class Parser {
  + parse(input: String): ParsedCommand
}

class CG2StocksTracker {
  + run()
}

class PortfolioBook {
  + hasActivePortfolio(): boolean
  + getActivePortfolio(): Portfolio
  + getPortfolios(): List<Portfolio>
}

class Portfolio {
  + getHoldings(): List<Holding>
  + getPricedTotalValue(): double
}

class Ui {
  + showHoldings(portfolio: Portfolio)
  + showPortfolios(portfolioBook: PortfolioBook)
  + showPortfolioSummaries(portfolioBook: PortfolioBook)
}

CG2StocksTracker ..> PortfolioBook
CG2StocksTracker ..> Portfolio
CG2StocksTracker ..> Ui : showHoldings/showPortfolios/showPortfolioSummaries
@enduml
