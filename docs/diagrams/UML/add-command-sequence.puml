@startuml
title /add Sequence

actor User
participant ":Ui" as Ui
participant ":CG2StocksTracker" as CG2StocksTracker
participant ":Parser" as Parser
participant ":ParsedCommand" as ParsedCommand
participant ":PortfolioBook" as PortfolioBook
participant ":Portfolio" as Portfolio
participant ":Storage" as Storage
User -> Ui : /add --type ... --ticker ... --qty ... --price ...
Ui -> CG2StocksTracker : command text
CG2StocksTracker -> Parser : parse(...)
Parser --> CG2StocksTracker : ADD command
CG2StocksTracker -> ParsedCommand : totalFees()
CG2StocksTracker -> PortfolioBook : getActivePortfolio()
PortfolioBook --> CG2StocksTracker : Portfolio
CG2StocksTracker -> Portfolio : addHolding(..., fees)
CG2StocksTracker -> Storage : save(...)
CG2StocksTracker -> Ui : show add/update output
@enduml
