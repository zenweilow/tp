@startuml
title Command Dispatch Main Flow

actor User
participant ":Ui" as Ui
participant ":CG2StocksTracker" as CG2StocksTracker
participant ":Parser" as Parser
participant ":ParsedCommand" as ParsedCommand
participant ":Model" as Model
participant ":Storage" as Storage
User -> Ui : enter command text
Ui -> CG2StocksTracker : readCommand()
CG2StocksTracker -> Parser : parse(input)
Parser --> CG2StocksTracker : ParsedCommand
CG2StocksTracker -> ParsedCommand : type()

alt state-changing command
  CG2StocksTracker -> Model : execute mutation
  CG2StocksTracker -> Storage : save(...)
else read-only command
  CG2StocksTracker -> Model : execute query
end

CG2StocksTracker -> Ui : show output
Ui --> User : response
@enduml
