@startuml
title Watch Command Class View
hide circle

class Parser {
  + parse(input: String): ParsedCommand
}

class CG2StocksTracker {
  + run()
}

class Watchlist {
  + addItem(assetType: AssetType, ticker: String, targetPrice: Double)
  + removeItem(assetType: AssetType, ticker: String): boolean
  + buyItem(...): BuyResult
  + getItems(): List<WatchlistItem>
}

class PortfolioBook {
  + getPortfolio(name: String): Portfolio
}

class Portfolio {
  + addHolding(...): double
}

class Storage {
  + save(portfolioBook: PortfolioBook)
  + saveWatchlist(watchlist: Watchlist)
}

class Ui {
  + showWatchlist(watchlist: Watchlist)
  + showMessage(message: String)
}

CG2StocksTracker ..> Watchlist : add/remove/list/buy
Watchlist ..> PortfolioBook : buyItem(...)
PortfolioBook *-- Portfolio
CG2StocksTracker ..> Storage : save() for mutating actions
CG2StocksTracker ..> Ui : show watch output
@enduml
